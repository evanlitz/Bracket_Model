# Normalize line endings to LF on commit, checkout as-is on Windows
* text=auto

# Source files — always LF
*.py   text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.css  text eol=lf
*.html text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.toml text eol=lf

# Binary files — no line ending conversion
*.png     binary
*.jpg     binary
*.parquet binary
*.pkl     binary
*.joblib  binary
